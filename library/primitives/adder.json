{
    "name": "Adder",
    "category": "primitives",
    "description": "Generic adder with carry out. SIG_TYPE controls signed/unsigned interpretation.",
    "ports": [
        {
            "name": "a",
            "direction": "in",
            "signal_type": {
                "kind": "SIG_TYPE",
                "width": "WIDTH",
                "lsb": "0"
            },
            "position": [
                0,
                2
            ],
            "is_clock": false,
            "is_reset": false
        },
        {
            "name": "b",
            "direction": "in",
            "signal_type": {
                "kind": "SIG_TYPE",
                "width": "WIDTH",
                "lsb": "0"
            },
            "position": [
                0,
                4
            ],
            "is_clock": false,
            "is_reset": false
        },
        {
            "name": "cin",
            "direction": "in",
            "signal_type": {
                "kind": "std_logic",
                "width": "1",
                "lsb": "0"
            },
            "position": [
                0,
                5
            ],
            "is_clock": false,
            "is_reset": false
        },
        {
            "name": "sum",
            "direction": "out",
            "signal_type": {
                "kind": "SIG_TYPE",
                "width": "WIDTH+1",
                "lsb": "0"
            },
            "position": [
                5,
                3
            ],
            "is_clock": false,
            "is_reset": false
        },
        {
            "name": "cout",
            "direction": "out",
            "signal_type": {
                "kind": "std_logic",
                "width": "1",
                "lsb": "0"
            },
            "position": [
                5,
                5
            ],
            "is_clock": false,
            "is_reset": false
        }
    ],
    "generics": [
        {
            "name": "WIDTH",
            "data_type": "integer",
            "default_value": 8
        },
        {
            "name": "SIG_TYPE",
            "data_type": "signal_kind",
            "default_value": "signed"
        }
    ],
    "visual": {
        "width": 5,
        "height": 6,
        "color": "#ed7d31"
    },
    "latency": 0,
    "behavior": {
        "code": "carry_in = 1 if cin else 0\ntotal = a + b + carry_in\ncout = total >> WIDTH\nreturn total, cout"
    }
}