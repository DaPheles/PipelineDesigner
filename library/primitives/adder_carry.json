{
    "name": "Adder_Carry",
    "category": "primitives",
    "description": "Generic adder with carry out. SIG_TYPE controls signed/unsigned interpretation.",
    "ports": [
        {
            "name": "a",
            "direction": "in",
            "signal_type": {
                "kind": "SIG_TYPE",
                "width": "WIDTH",
                "lsb": "LSB"
            },
            "position": [
                0,
                2
            ],
            "signal_class": "data"
        },
        {
            "name": "b",
            "direction": "in",
            "signal_type": {
                "kind": "SIG_TYPE",
                "width": "WIDTH",
                "lsb": "LSB"
            },
            "position": [
                0,
                4
            ],
            "signal_class": "data"
        },
        {
            "name": "cin",
            "direction": "in",
            "signal_type": {
                "kind": "std_logic",
                "width": "1",
                "lsb": "0"
            },
            "position": [
                0,
                5
            ],
            "signal_class": "data"
        },
        {
            "name": "sum",
            "direction": "out",
            "signal_type": {
                "kind": "SIG_TYPE",
                "width": "WIDTH+1",
                "lsb": "LSB"
            },
            "position": [
                4,
                3
            ],
            "signal_class": "data"
        },
        {
            "name": "cout",
            "direction": "out",
            "signal_type": {
                "kind": "std_logic",
                "width": "1",
                "lsb": "0"
            },
            "position": [
                4,
                5
            ],
            "signal_class": "data"
        }
    ],
    "generics": [
        {
            "name": "WIDTH",
            "data_type": "integer",
            "default_value": 8
        },
        {
            "name": "LSB",
            "data_type": "integer",
            "default_value": 0
        },
        {
            "name": "SIG_TYPE",
            "data_type": "signal_kind",
            "default_value": "signed"
        }
    ],
    "visual": {
        "width": 4,
        "height": 6,
        "color": "#ed7d31"
    },
    "latency": 0,
    "behavior": {
        "code": "carry_in = 1 if cin else 0\ntotal = a + b + carry_in\nsum = total & ((1 << WIDTH)-1)\ncout = total >> WIDTH\nreturn sum, cout"
    }
}