{
    "name": "FIR4Tap",
    "category": "DSP",
    "description": "4-tap box-average FIR filter (h=[0.25,0.25,0.25,0.25]). Computes y = 0.25*(x0+x1+x2+x3). x0 is the newest sample, x3 the oldest.",
    "generics": [],
    "ports": [
        {
            "name": "x0",
            "direction": "IN",
            "data_type": "sfixed",
            "vector_range": "0:-15"
        },
        {
            "name": "x1",
            "direction": "IN",
            "data_type": "sfixed",
            "vector_range": "0:-15"
        },
        {
            "name": "x2",
            "direction": "IN",
            "data_type": "sfixed",
            "vector_range": "0:-15"
        },
        {
            "name": "x3",
            "direction": "IN",
            "data_type": "sfixed",
            "vector_range": "0:-15"
        },
        {
            "name": "y",
            "direction": "OUT",
            "data_type": "sfixed",
            "vector_range": "1:-15"
        }
    ],
    "visual": {
        "width": 6,
        "height": 8,
        "color": "#3a7abf",
        "port_positions": {
            "x0": [0, 2],
            "x1": [0, 3],
            "x2": [0, 4],
            "x3": [0, 5],
            "y":  [6, 4]
        }
    },
    "latency": 1,
    "behavior": {
        "port_types": {
            "x0": {"kind": "sfixed", "msb": "0", "lsb": "-15"},
            "x1": {"kind": "sfixed", "msb": "0", "lsb": "-15"},
            "x2": {"kind": "sfixed", "msb": "0", "lsb": "-15"},
            "x3": {"kind": "sfixed", "msb": "0", "lsb": "-15"},
            "y":  {"kind": "sfixed", "msb": "1", "lsb": "-15"}
        },
        "code": "# Box-average FIR: multiply each tap by 0.25 then accumulate\ncoef_fmt = UFixed(0, -15)          # U1.15 — 0.25 is exact\nout_fmt  = SFixed(1, -15)          # S2.15 — enough headroom for sum\nc = Const(coef_fmt, 0.25)\nm0 = (x0 * c).keep_full()\nm1 = (x1 * c).keep_full()\nm2 = (x2 * c).keep_full()\nm3 = (x3 * c).keep_full()\nacc = ((m0 + m1).keep_full() + (m2 + m3).keep_full()).keep_full()\nreturn acc.requantize(out_fmt, round='truncate', saturate='saturate')\n"
    }
}
