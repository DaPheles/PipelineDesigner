{
    "name": "FP_U2U",
    "category": "fixed_point",
    "description": "FixedPoint convertion of unsigned numbers",
    "ports": [
        {
            "name": "a",
            "direction": "in",
            "signal_class": "data",
            "signal_type": {
                "kind": "ufixed",
                "width": "A_WIDTH",
                "lsb": "A_LSB"
            },
            "position": [
                0,
                3
            ]
        },
        {
            "name": "q",
            "direction": "out",
            "signal_class": "data",
            "signal_type": {
                "kind": "ufixed",
                "width": "Q_WIDTH",
                "lsb": "Q_LSB"
            },
            "position": [
                4,
                3
            ]
        }
    ],
    "generics": [
        {
            "name": "A_WIDTH",
            "data_type": "integer",
            "default_value": 16
        },
        {
            "name": "A_LSB",
            "data_type": "integer",
            "default_value": 0
        },
        {
            "name": "Q_WIDTH",
            "data_type": "integer",
            "default_value": 16
        },
        {
            "name": "Q_LSB",
            "data_type": "integer",
            "default_value": 0
        },
        {
            "name": "CLAMP_EN",
            "data_type": "integer",
            "default_value": 1
        }
    ],
    "visual": {
        "width": 4,
        "height": 6,
        "color": "#4a90d9"
    },
    "latency": 0,
    "behavior": {
        "code": "q_fmt  = UFixed(Q_WIDTH + Q_LSB - 1, Q_LSB)\na_real = float(a)\nif CLAMP_EN:\n    a_real = max(q_fmt.real_min, min(q_fmt.real_max, a_real))\nreturn q_fmt.quantize(np.array(a_real))"
    }
}