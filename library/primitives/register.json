{
    "name": "Register",
    "category": "primitives",
    "description": "Basic D flip-flop register with synchronous reset",
    "ports": [
        {
            "name": "clk",
            "direction": "in",
            "signal_type": {"kind": "std_logic"},
            "position": [2, 8],
            "is_clock": true,
            "is_reset": false
        },
        {
            "name": "rst",
            "direction": "in",
            "signal_type": {"kind": "std_logic"},
            "position": [1, 0],
            "is_clock": false,
            "is_reset": true
        },
        {
            "name": "d",
            "direction": "in",
            "signal_type": {"kind": "std_logic_vector", "width": "WIDTH", "lsb": "0"},
            "position": [0, 4],
            "is_clock": false,
            "is_reset": false
        },
        {
            "name": "q",
            "direction": "out",
            "signal_type": {"kind": "std_logic_vector", "width": "WIDTH", "lsb": "0"},
            "position": [4, 4],
            "is_clock": false,
            "is_reset": false
        }
    ],
    "generics": [
        {
            "name": "WIDTH",
            "data_type": "integer",
            "default_value": 8
        }
    ],
    "visual": {
        "width": 4,
        "height": 8,
        "color": "#5b9bd5"
    },
    "latency": 1,
    "behavior": {
        "code": "# On every rising clock edge:\n#   if rst = '1'  →  q <= (others => '0')\n#   else           →  q <= d\nreturn d"
    }
}
