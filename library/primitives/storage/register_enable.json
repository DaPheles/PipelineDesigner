{
    "name": "Register_Enable",
    "category": "storage",
    "description": "Basic D flip-flop register with synchronous reset",
    "ports": [
        {
            "name": "clk",
            "direction": "in",
            "signal_class": "clock",
            "signal_type": {
                "kind": "std_logic",
                "width": "1",
                "lsb": "0"
            },
            "position": [
                2,
                8
            ]
        },
        {
            "name": "en",
            "direction": "in",
            "signal_class": "control",
            "signal_type": {
                "kind": "std_logic",
                "width": "1",
                "lsb": "0"
            },
            "position": [
                0,
                2
            ]
        },
        {
            "name": "d",
            "direction": "in",
            "signal_class": "data",
            "signal_type": {
                "kind": "sfixed",
                "width": "WIDTH",
                "lsb": "LSB"
            },
            "position": [
                0,
                4
            ]
        },
        {
            "name": "q",
            "direction": "out",
            "signal_class": "data",
            "signal_type": {
                "kind": "sfixed",
                "width": "WIDTH",
                "lsb": "LSB"
            },
            "position": [
                4,
                4
            ]
        }
    ],
    "generics": [
        {
            "name": "WIDTH",
            "data_type": "integer",
            "default_value": 8
        },
        {
            "name": "LSB",
            "data_type": "integer",
            "default_value": 0
        }
    ],
    "visual": {
        "width": 4,
        "height": 8,
        "color": "#5b9bd5"
    },
    "latency": 1,
    "behavior": {
        "code": "# D flip-flop with enable\nif 'q' not in state:\n    state['q'] = 0.0\nif en:\n    state['q'] = d\nreturn state['q']"
    }
}